<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.agent.hopaw.infra.mapper.SysConfigMapper">

    <resultMap id="SysConfigResultMap" type="com.agent.hopaw.infra.model.entity.SysConfig">
        <id property="id" column="id"/>
        <result property="configKey" column="config_key"/>
        <result property="configValue" column="config_value"/>
        <result property="description" column="description"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="findAll" resultMap="SysConfigResultMap">
        SELECT id, config_key, config_value, description, create_time, update_time
        FROM sys_config
        ORDER BY id DESC
    </select>

    <select id="findByKey" resultMap="SysConfigResultMap">
        SELECT id, config_key, config_value, description, create_time, update_time
        FROM sys_config
        WHERE config_key = #{key}
    </select>

    <insert id="insert" parameterType="com.agent.hopaw.infra.model.entity.SysConfig">
        INSERT INTO sys_config (config_key, config_value, description)
        VALUES (#{configKey}, #{configValue}, #{description})
        <selectKey resultType="long" keyProperty="id" order="AFTER">
            SELECT last_insert_rowid()
        </selectKey>
    </insert>

    <update id="update" parameterType="com.agent.hopaw.infra.model.entity.SysConfig">
        UPDATE sys_config
        SET config_value = #{configValue},
            description = #{description},
            update_time = datetime('now', 'localtime')
        WHERE config_key = #{configKey}
    </update>

    <delete id="deleteById">
        DELETE FROM sys_config WHERE id = #{id}
    </delete>

    <delete id="deleteByKey">
        DELETE FROM sys_config WHERE config_key = #{key}
    </delete>

</mapper>
