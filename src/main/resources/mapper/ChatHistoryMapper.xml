<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.agent.hopaw.mapper.ChatHistoryMapper">
    
    <resultMap id="ChatHistoryResultMap" type="com.agent.hopaw.model.ChatHistory">
        <id property="id" column="id"/>
        <result property="agentId" column="agent_id"/>
        <result property="role" column="role"/>
        <result property="messageType" column="message_type"/>
        <result property="content" column="content"/>
        <result property="toolCallId" column="tool_call_id"/>
        <result property="toolName" column="tool_name"/>
        <result property="toolArguments" column="tool_arguments"/>
        <result property="createTime" column="create_time"/>
    </resultMap>
    
    <select id="findByAgentId" resultMap="ChatHistoryResultMap">
        SELECT id, agent_id, role, message_type, content, tool_call_id, tool_name, tool_arguments, create_time 
        FROM chat_history 
        WHERE agent_id = #{agentId} 
        ORDER BY create_time ASC
    </select>
    
    <insert id="insert" parameterType="com.agent.hopaw.model.ChatHistory">
        INSERT INTO chat_history (agent_id, role, message_type, content, tool_call_id, tool_name, tool_arguments, create_time) 
        VALUES (#{agentId}, #{role}, #{messageType}, #{content}, #{toolCallId}, #{toolName}, #{toolArguments}, #{createTime})
    </insert>
    
    <delete id="deleteByAgentId">
        DELETE FROM chat_history WHERE agent_id = #{agentId}
    </delete>
    
</mapper>
