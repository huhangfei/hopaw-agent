<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.agent.hopaw.mapper.TokenUsageMapper">

    <resultMap id="TokenUsageResultMap" type="com.agent.hopaw.model.TokenUsage">
        <id property="id" column="id"/>
        <result property="agentId" column="agent_id"/>
        <result property="modelName" column="model_name"/>
        <result property="inputTokens" column="input_tokens"/>
        <result property="outputTokens" column="output_tokens"/>
        <result property="totalTokens" column="total_tokens"/>
        <result property="userId" column="user_id"/>
        <result property="source" column="source"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <insert id="insert" parameterType="com.agent.hopaw.model.TokenUsage">
        INSERT INTO token_usage (agent_id, model_name, input_tokens, output_tokens, total_tokens, user_id, source, create_time)
        VALUES (#{agentId}, #{modelName}, #{inputTokens}, #{outputTokens}, #{totalTokens}, #{userId}, #{source}, #{createTime})
    </insert>

    <sql id="timeRangeFilter">
        <if test="startTime != null">AND create_time &gt;= #{startTime}</if>
        <if test="endTime != null">AND create_time &lt;= #{endTime}</if>
    </sql>

    <sql id="searchFilter">
        <if test="userId != null and userId != ''">AND user_id = #{userId}</if>
        <if test="agentId != null">AND agent_id = #{agentId}</if>
        <if test="modelName != null and modelName != ''">AND model_name = #{modelName}</if>
        <if test="source != null and source != ''">AND source = #{source}</if>
    </sql>

    <select id="findByTimeRange" resultMap="TokenUsageResultMap">
        SELECT id, agent_id, model_name, input_tokens, output_tokens, total_tokens, user_id, source, create_time
        FROM token_usage
        WHERE 1=1
        <include refid="timeRangeFilter"/>
        <include refid="searchFilter"/>
        ORDER BY create_time DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countByTimeRange" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM token_usage
        WHERE 1=1
        <include refid="timeRangeFilter"/>
        <include refid="searchFilter"/>
    </select>

    <select id="summaryByTimeRange" resultMap="TokenUsageResultMap">
        SELECT
            COALESCE(SUM(input_tokens), 0) AS input_tokens,
            COALESCE(SUM(output_tokens), 0) AS output_tokens,
            COALESCE(SUM(total_tokens), 0) AS total_tokens,
            COUNT(*) AS id
        FROM token_usage
        WHERE 1=1
        <include refid="timeRangeFilter"/>
        <include refid="searchFilter"/>
    </select>

    <select id="dailyStatsByTimeRange" resultType="java.util.HashMap">
        SELECT
            strftime('%Y-%m-%d', create_time) AS date,
            COALESCE(SUM(input_tokens), 0) AS inputTokens,
            COALESCE(SUM(output_tokens), 0) AS outputTokens,
            COALESCE(SUM(total_tokens), 0) AS totalTokens
        FROM token_usage
        WHERE 1=1
        <include refid="timeRangeFilter"/>
        <include refid="searchFilter"/>
        GROUP BY strftime('%Y-%m-%d', create_time)
        ORDER BY date ASC
    </select>
</mapper>
