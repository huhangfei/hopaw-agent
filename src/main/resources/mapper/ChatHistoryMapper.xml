<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.agent.hopaw.mapper.ChatHistoryMapper">
    
    <resultMap id="ChatHistoryResultMap" type="com.agent.hopaw.model.ChatHistory">
        <id property="id" column="id"/>
        <result property="agentId" column="agent_id"/>
        <result property="role" column="role"/>
        <result property="content" column="content"/>
        <result property="createTime" column="create_time"/>
    </resultMap>
    
    <select id="findByAgentId" resultMap="ChatHistoryResultMap">
        SELECT id, agent_id, role, content, create_time 
        FROM chat_history 
        WHERE agent_id = #{agentId} 
        ORDER BY create_time ASC
    </select>
    
    <insert id="insert" parameterType="com.agent.hopaw.model.ChatHistory">
        INSERT INTO chat_history (agent_id, role, content, create_time) 
        VALUES (#{agentId}, #{role}, #{content}, #{createTime})
    </insert>
    
    <delete id="deleteByAgentId">
        DELETE FROM chat_history WHERE agent_id = #{agentId}
    </delete>
    
</mapper>
